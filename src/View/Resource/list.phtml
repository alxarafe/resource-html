<?php
/**
 * Vista de listado para ResourceController — HTML puro.
 *
 * Variables disponibles:
 *   $struct       — Configuración de la estructura (tabs, columnas, botones, etc.)
 *   $activeTab    — ID de la pestaña activa
 *   $primaryColumn — Nombre de la columna clave primaria
 *   $action       — URL de acción del formulario
 *   $buttons      — Botones del header
 *   $listData     — Datos de la lista (data, meta)
 *   $messages     — Mensajes flash
 *   $t            — Callable traductor: $t('key')
 */

$columns = $struct['list']['tabs'][$activeTab]['columns'] ?? [];
$rows = $listData['data'] ?? [];
$total = $listData['meta']['total'] ?? 0;
$limit = $struct['list']['limit'] ?? 50;
$offset = $listData['meta']['offset'] ?? 0;
?>
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold text-dark">
            <i class="fas fa-list me-2 text-primary"></i><?= htmlspecialchars($t('list'), ENT_QUOTES, 'UTF-8') ?>
        </h1>
        <div class="d-flex gap-2">
            <?php foreach ($buttons as $btn): ?>
                <?php if (($btn['action'] ?? '') === 'submit'): ?>
                    <button type="submit" form="resource-form" class="btn btn-<?= htmlspecialchars($btn['type'] ?? 'primary') ?>">
                        <i class="<?= htmlspecialchars($btn['icon'] ?? '') ?> me-1"></i>
                        <?= htmlspecialchars($t($btn['label'] ?? '')) ?>
                    </button>
                <?php else: ?>
                    <a href="<?= htmlspecialchars($btn['target'] ?? '#') ?>" class="btn btn-<?= htmlspecialchars($btn['type'] ?? 'secondary') ?>">
                        <i class="<?= htmlspecialchars($btn['icon'] ?? '') ?> me-1"></i>
                        <?= htmlspecialchars($t($btn['label'] ?? '')) ?>
                    </a>
                <?php endif; ?>
            <?php endforeach; ?>
        </div>
    </div>

    <?php foreach ($messages as $msg): ?>
        <div class="alert alert-<?= htmlspecialchars($msg['level'] ?? 'info') ?> alert-dismissible fade show" role="alert">
            <?= htmlspecialchars($msg['text'] ?? '') ?>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <?php endforeach; ?>

    <div class="card resource-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <?php foreach ($columns as $col): ?>
                                <?php
                                    $colData = $col;
                                    if (is_object($col) && method_exists($col, 'jsonSerialize')) {
                                        $colData = $col->jsonSerialize();
                                    }
                                ?>
                                <th class="px-3 py-3"><?= htmlspecialchars($colData['label'] ?? '') ?></th>
                            <?php endforeach; ?>
                            <th class="px-3 py-3 text-end"><?= htmlspecialchars($t('actions')) ?></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php if (empty($rows)): ?>
                            <tr>
                                <td colspan="<?= count($columns) + 1 ?>" class="text-center py-5 text-muted">
                                    <i class="fas fa-inbox fa-2x mb-3 d-block opacity-50"></i>
                                    <?= htmlspecialchars($t('no-results-found')) ?>
                                </td>
                            </tr>
                        <?php else: ?>
                            <?php foreach ($rows as $row): ?>
                                <tr>
                                    <?php foreach ($columns as $col): ?>
                                        <?php
                                            $colData = $col;
                                            if (is_object($col) && method_exists($col, 'jsonSerialize')) {
                                                $colData = $col->jsonSerialize();
                                            }
                                            $field = $colData['field'] ?? '';
                                            $value = $row[$field] ?? '';
                                            $type = $colData['type'] ?? $colData['component'] ?? 'text';
                                        ?>
                                        <td class="px-3">
                                            <?php if ($type === 'boolean'): ?>
                                                <?php if ($value): ?>
                                                    <span class="badge bg-success"><i class="fas fa-check"></i></span>
                                                <?php else: ?>
                                                    <span class="badge bg-secondary"><i class="fas fa-times"></i></span>
                                                <?php endif; ?>
                                            <?php elseif ($type === 'decimal'): ?>
                                                <?= htmlspecialchars(number_format((float)$value, 2, ',', '.')) ?>
                                            <?php elseif ($type === 'date'): ?>
                                                <?= htmlspecialchars($value ? date('d/m/Y', strtotime($value)) : '') ?>
                                            <?php elseif ($type === 'datetime'): ?>
                                                <?= htmlspecialchars($value ? date('d/m/Y H:i', strtotime($value)) : '') ?>
                                            <?php else: ?>
                                                <?= htmlspecialchars((string)$value) ?>
                                            <?php endif; ?>
                                        </td>
                                    <?php endforeach; ?>
                                    <td class="px-3 text-end">
                                        <a href="<?= htmlspecialchars($action) ?>&amp;id=<?= htmlspecialchars((string)($row[$primaryColumn] ?? '')) ?>"
                                           class="btn btn-sm btn-outline-primary" title="<?= htmlspecialchars($t('edit') ?? 'Edit') ?>">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </td>
                                </tr>
                            <?php endforeach; ?>
                        <?php endif; ?>
                    </tbody>
                </table>
            </div>
        </div>
        <?php if ($total > $limit): ?>
            <div class="card-footer bg-transparent border-top-0 py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted small">
                        <?= htmlspecialchars(sprintf($t('showing-x-of-total') ?: 'Mostrando %d de %d', min($limit, $total), $total)) ?>
                    </span>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <?php
                            $totalPages = (int)ceil($total / $limit);
                            $currentPage = (int)floor($offset / $limit) + 1;
                            $baseUrl = $action . '&tab=' . urlencode($activeTab);
                            ?>
                            <li class="page-item <?= $currentPage <= 1 ? 'disabled' : '' ?>">
                                <a class="page-link" href="<?= htmlspecialchars($baseUrl . '&offset=' . max(0, $offset - $limit)) ?>">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                            <?php for ($p = max(1, $currentPage - 2); $p <= min($totalPages, $currentPage + 2); $p++): ?>
                                <li class="page-item <?= $p === $currentPage ? 'active' : '' ?>">
                                    <a class="page-link" href="<?= htmlspecialchars($baseUrl . '&offset=' . (($p - 1) * $limit)) ?>"><?= $p ?></a>
                                </li>
                            <?php endfor; ?>
                            <li class="page-item <?= $currentPage >= $totalPages ? 'disabled' : '' ?>">
                                <a class="page-link" href="<?= htmlspecialchars($baseUrl . '&offset=' . min(($totalPages - 1) * $limit, $offset + $limit)) ?>">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        <?php endif; ?>
    </div>
</div>
