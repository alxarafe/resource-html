<?php
/**
 * Vista de edición para ResourceController — HTML puro.
 *
 * Variables disponibles:
 *   $struct        — Configuración (sections, fields, head_buttons)
 *   $action        — URL de acción del formulario
 *   $recordId      — ID del registro (o 'new')
 *   $record        — Datos del registro actual
 *   $buttons       — Botones del header
 *   $body          — Componente Panel/TabGroup del body (componentes anidados)
 *   $messages      — Mensajes flash
 *   $t             — Callable traductor: $t('key')
 *   $csrfToken     — Token CSRF
 */

$isNew = ($recordId === null || $recordId === 'new');
$formAction = $action . ($recordId ? '&id=' . urlencode((string)$recordId) : '');

/**
 * Renders a field component to HTML.
 */
function renderField(array $fieldData, array $record, string $prefix = 'data'): string
{
    $field = $fieldData['field'] ?? '';
    $label = $fieldData['label'] ?? ucfirst($field);
    $type = $fieldData['type'] ?? $fieldData['component'] ?? 'text';
    $required = !empty($fieldData['required']);
    $readonly = !empty($fieldData['readonly']);
    $col = $fieldData['col'] ?? 'col-md-6';
    $value = $record[$field] ?? $fieldData['default'] ?? '';
    $name = $prefix . '[' . htmlspecialchars($field) . ']';
    $id = 'field-' . htmlspecialchars($field);

    $requiredAttr = $required ? ' required' : '';
    $readonlyAttr = $readonly ? ' readonly' : '';
    $maxlength = isset($fieldData['maxlength']) ? ' maxlength="' . (int)$fieldData['maxlength'] . '"' : '';

    $html = '<div class="' . htmlspecialchars($col) . ' mb-3">';
    $html .= '<label for="' . $id . '" class="form-label">' . htmlspecialchars($label);
    if ($required) {
        $html .= ' <span class="text-danger">*</span>';
    }
    $html .= '</label>';

    switch ($type) {
        case 'boolean':
            $checked = $value ? ' checked' : '';
            $html .= '<div class="form-check form-switch">';
            $html .= '<input type="hidden" name="' . $name . '" value="0">';
            $html .= '<input class="form-check-input" type="checkbox" id="' . $id . '" name="' . $name . '" value="1"' . $checked . $readonlyAttr . '>';
            $html .= '</div>';
            break;

        case 'textarea':
            $html .= '<textarea class="form-control" id="' . $id . '" name="' . $name . '" rows="4"' . $requiredAttr . $readonlyAttr . '>'
                . htmlspecialchars((string)$value) . '</textarea>';
            break;

        case 'integer':
            $html .= '<input type="number" step="1" class="form-control" id="' . $id . '" name="' . $name . '"'
                . ' value="' . htmlspecialchars((string)$value) . '"' . $requiredAttr . $readonlyAttr . '>';
            break;

        case 'decimal':
            $html .= '<input type="number" step="0.01" class="form-control" id="' . $id . '" name="' . $name . '"'
                . ' value="' . htmlspecialchars((string)$value) . '"' . $requiredAttr . $readonlyAttr . '>';
            break;

        case 'date':
            $html .= '<input type="date" class="form-control" id="' . $id . '" name="' . $name . '"'
                . ' value="' . htmlspecialchars((string)$value) . '"' . $requiredAttr . $readonlyAttr . '>';
            break;

        case 'datetime':
            $html .= '<input type="datetime-local" class="form-control" id="' . $id . '" name="' . $name . '"'
                . ' value="' . htmlspecialchars((string)$value) . '"' . $requiredAttr . $readonlyAttr . '>';
            break;

        case 'time':
            $html .= '<input type="time" class="form-control" id="' . $id . '" name="' . $name . '"'
                . ' value="' . htmlspecialchars((string)$value) . '"' . $requiredAttr . $readonlyAttr . '>';
            break;

        case 'hidden':
            $html = '<input type="hidden" id="' . $id . '" name="' . $name . '"'
                . ' value="' . htmlspecialchars((string)$value) . '">';
            return $html;

        case 'select':
            $choices = $fieldData['choices'] ?? $fieldData['options']['choices'] ?? [];
            $html .= '<select class="form-select" id="' . $id . '" name="' . $name . '"' . $requiredAttr . $readonlyAttr . '>';
            $html .= '<option value="">--</option>';
            foreach ($choices as $k => $v) {
                $selected = ((string)$k === (string)$value) ? ' selected' : '';
                $html .= '<option value="' . htmlspecialchars((string)$k) . '"' . $selected . '>' . htmlspecialchars($v) . '</option>';
            }
            $html .= '</select>';
            break;

        case 'select2':
            $choices = $fieldData['choices'] ?? $fieldData['options']['choices'] ?? [];
            $html .= '<select class="form-select" id="' . $id . '" name="' . $name . '"' . $requiredAttr . $readonlyAttr . '>';
            $html .= '<option value="">--</option>';
            foreach ($choices as $k => $v) {
                $selected = ((string)$k === (string)$value) ? ' selected' : '';
                $html .= '<option value="' . htmlspecialchars((string)$k) . '"' . $selected . '>' . htmlspecialchars($v) . '</option>';
            }
            $html .= '</select>';
            break;

        default: // text
            $html .= '<input type="text" class="form-control" id="' . $id . '" name="' . $name . '"'
                . ' value="' . htmlspecialchars((string)$value) . '"' . $requiredAttr . $readonlyAttr . $maxlength . '>';
            break;
    }

    $html .= '</div>';
    return $html;
}

/**
 * Renders a component tree (Panel, Tab, TabGroup, Row, Field) to HTML.
 */
function renderComponent($component, array $record, callable $t): string
{
    if ($component instanceof \JsonSerializable) {
        $data = $component->jsonSerialize();
    } elseif (is_array($component)) {
        $data = $component;
    } else {
        return '';
    }

    $containerType = $data['containerType'] ?? $data['component'] ?? $data['type'] ?? 'field';

    // Tab Group
    if ($containerType === 'tab_group' || $component instanceof \Alxarafe\ResourceController\Component\Container\TabGroup) {
        $children = [];
        if (is_object($component) && method_exists($component, 'getFields')) {
            $children = $component->getFields();
        } else {
            $children = $data['children'] ?? [];
        }

        $html = '<ul class="nav nav-tabs" role="tablist">';
        foreach ($children as $i => $tab) {
            $tabData = ($tab instanceof \JsonSerializable) ? $tab->jsonSerialize() : $tab;
            $tabId = $tabData['tabId'] ?? $tabData['field'] ?? 'tab-' . $i;
            $tabLabel = $tabData['label'] ?? '';
            $tabIcon = $tabData['icon'] ?? '';
            $active = ($i === 0) ? ' active' : '';
            $html .= '<li class="nav-item" role="presentation">';
            $html .= '<button class="nav-link' . $active . '" data-bs-toggle="tab" data-bs-target="#' . htmlspecialchars($tabId) . '" type="button" role="tab">';
            if ($tabIcon) {
                $html .= '<i class="' . htmlspecialchars($tabIcon) . ' me-1"></i>';
            }
            $html .= htmlspecialchars($t($tabLabel));
            if (isset($tabData['badge'])) {
                $html .= ' <span class="badge bg-secondary ms-1">' . (int)$tabData['badge'] . '</span>';
            }
            $html .= '</button></li>';
        }
        $html .= '</ul>';

        $html .= '<div class="tab-content border border-top-0 rounded-bottom p-3">';
        foreach ($children as $i => $tab) {
            $tabData = ($tab instanceof \JsonSerializable) ? $tab->jsonSerialize() : $tab;
            $tabId = $tabData['tabId'] ?? $tabData['field'] ?? 'tab-' . $i;
            $active = ($i === 0) ? ' show active' : '';
            $tabChildren = [];
            if (is_object($tab) && method_exists($tab, 'getFields')) {
                $tabChildren = $tab->getFields();
            } else {
                $tabChildren = $tabData['children'] ?? [];
            }
            $html .= '<div class="tab-pane fade' . $active . '" id="' . htmlspecialchars($tabId) . '" role="tabpanel">';
            foreach ($tabChildren as $child) {
                $html .= renderComponent($child, $record, $t);
            }
            $html .= '</div>';
        }
        $html .= '</div>';
        return $html;
    }

    // Panel
    if ($containerType === 'panel' || $component instanceof \Alxarafe\ResourceController\Component\Container\Panel) {
        $label = $data['label'] ?? '';
        $col = $data['col'] ?? 'col-12';
        $cssClass = $data['class'] ?? '';
        $fullWidth = !empty($data['full_width']);
        $children = [];
        if (is_object($component) && method_exists($component, 'getFields')) {
            $children = $component->getFields();
        } else {
            $children = $data['children'] ?? [];
        }

        $html = '<div class="' . htmlspecialchars($col) . ' mb-3">';
        $html .= '<div class="card resource-card ' . htmlspecialchars($cssClass) . '">';
        if ($label) {
            $html .= '<div class="card-header bg-white"><h6 class="mb-0 fw-bold">' . htmlspecialchars($t($label)) . '</h6></div>';
        }
        $html .= '<div class="card-body"><div class="row">';
        foreach ($children as $child) {
            $html .= renderComponent($child, $record, $t);
        }
        $html .= '</div></div></div></div>';
        return $html;
    }

    // Row
    if ($containerType === 'row' || $component instanceof \Alxarafe\ResourceController\Component\Container\Row) {
        $col = $data['col'] ?? 'col-12';
        $children = [];
        if (is_object($component) && method_exists($component, 'getFields')) {
            $children = $component->getFields();
        } else {
            $children = $data['children'] ?? [];
        }
        $html = '<div class="' . htmlspecialchars($col) . '"><div class="row">';
        foreach ($children as $child) {
            $html .= renderComponent($child, $record, $t);
        }
        $html .= '</div></div>';
        return $html;
    }

    // Detail Lines
    if ($containerType === 'detail_lines') {
        $label = $data['label'] ?? '';
        $lineColumns = $data['options']['columns'] ?? [];
        $html = '<div class="col-12 mb-3">';
        $html .= '<div class="card resource-card">';
        if ($label) {
            $html .= '<div class="card-header bg-white"><h6 class="mb-0 fw-bold">' . htmlspecialchars($t($label)) . '</h6></div>';
        }
        $html .= '<div class="card-body p-0">';
        $html .= '<div class="table-responsive"><table class="table table-sm table-hover mb-0">';
        $html .= '<thead><tr>';
        foreach ($lineColumns as $lc) {
            $lcData = ($lc instanceof \JsonSerializable) ? $lc->jsonSerialize() : $lc;
            $html .= '<th class="px-2">' . htmlspecialchars($lcData['label'] ?? '') . '</th>';
        }
        $html .= '<th class="px-2 text-end">—</th></tr></thead>';
        $html .= '<tbody><tr><td colspan="' . (count($lineColumns) + 1) . '" class="text-center text-muted py-3">';
        $html .= '<i class="fas fa-info-circle me-1"></i>' . htmlspecialchars($t('no-lines') ?: 'Sin líneas');
        $html .= '</td></tr></tbody>';
        $html .= '</table></div></div></div></div>';
        return $html;
    }

    // Tab (standalone — not inside TabGroup)
    if ($containerType === 'tab' || $component instanceof \Alxarafe\ResourceController\Component\Container\Tab) {
        $children = [];
        if (is_object($component) && method_exists($component, 'getFields')) {
            $children = $component->getFields();
        } else {
            $children = $data['children'] ?? [];
        }
        $html = '';
        foreach ($children as $child) {
            $html .= renderComponent($child, $record, $t);
        }
        return $html;
    }

    // Field — leaf node
    return renderField($data, $record);
}
?>
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold text-dark">
            <i class="fas fa-<?= $isNew ? 'plus-circle text-success' : 'edit text-primary' ?> me-2"></i>
            <?= htmlspecialchars($t($isNew ? 'create' : 'edit')) ?>
        </h1>
        <div class="d-flex gap-2">
            <?php foreach ($buttons as $btn): ?>
                <?php if (($btn['action'] ?? '') === 'submit'): ?>
                    <button type="submit" form="resource-form"
                            class="btn btn-<?= htmlspecialchars($btn['type'] ?? 'primary') ?>">
                        <i class="<?= htmlspecialchars($btn['icon'] ?? '') ?> me-1"></i>
                        <?= htmlspecialchars($t($btn['label'] ?? '')) ?>
                    </button>
                <?php else: ?>
                    <a href="<?= htmlspecialchars($btn['target'] ?? '#') ?>"
                       class="btn btn-<?= htmlspecialchars($btn['type'] ?? 'secondary') ?>">
                        <i class="<?= htmlspecialchars($btn['icon'] ?? '') ?> me-1"></i>
                        <?= htmlspecialchars($t($btn['label'] ?? '')) ?>
                    </a>
                <?php endif; ?>
            <?php endforeach; ?>
        </div>
    </div>

    <?php foreach ($messages as $msg): ?>
        <div class="alert alert-<?= htmlspecialchars($msg['level'] ?? 'info') ?> alert-dismissible fade show" role="alert">
            <?= htmlspecialchars($msg['text'] ?? '') ?>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <?php endforeach; ?>

    <form id="resource-form" action="<?= htmlspecialchars($formAction) ?>" method="post">
        <input type="hidden" name="action" value="save">
        <?php if (!empty($csrfToken)): ?>
            <input type="hidden" name="multireqtoken" value="<?= htmlspecialchars($csrfToken) ?>">
        <?php endif; ?>

        <?php if ($body !== null): ?>
            <div class="row">
                <?= renderComponent($body, $record, $t) ?>
            </div>
        <?php else: ?>
            <?php foreach ($struct['edit']['sections'] ?? [] as $sectionId => $section): ?>
                <div class="card resource-card mb-3">
                    <div class="card-header bg-white">
                        <h6 class="mb-0 fw-bold"><?= htmlspecialchars($section['title'] ?? ucfirst($sectionId)) ?></h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <?php foreach ($section['fields'] ?? [] as $field): ?>
                                <?php
                                    $fData = $field;
                                    if (is_object($field) && $field instanceof \JsonSerializable) {
                                        $fData = $field->jsonSerialize();
                                    }
                                ?>
                                <?= renderField($fData, $record) ?>
                            <?php endforeach; ?>
                        </div>
                    </div>
                </div>
            <?php endforeach; ?>
        <?php endif; ?>


    </form>
</div>
