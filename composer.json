{
  "name": "alxarafe/resource-html",
  "description": "HTML adapter for alxarafe/resource-controller. Provides a RendererContract implementation using pure PHP and HTML templates.",
  "version": "0.1.0",
  "type": "library",
  "license": "GPL-3.0-or-later",
  "keywords": ["html", "php", "renderer", "template", "resource-controller", "alxarafe"],
  "authors": [
    {
      "name": "Rafael San José",
      "email": "rsanjose@alxarafe.com",
      "homepage": "https://alxarafe.es",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "alxarafe/resource-controller": "^0.1"
  },
  "autoload": {
    "psr-4": {
      "Alxarafe\\ResourceHtml\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Alxarafe\\ResourceHtml\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10",
    "phpstan/phpstan": "^2.1",
    "vimeo/psalm": "^6.0"
  },
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true
  }
}
